# Prithvi — environment variables
# Copy this file: cp .env.example .env.local

# ──────────────────────────────────────────────
# REQUIRED for Gemini bill/receipt scanning
# Get a free key at: https://aistudio.google.com/apikey
# Without this key, the app still works — scanning just falls back to manual entry.
GEMINI_API_KEY=your_google_ai_studio_key_here

# ──────────────────────────────────────────────
# OPTIONAL: override the Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
